# Playwright E2E Testing Configuration
# Copy this file to .env and fill in your values

# API Server URL (backend)
API_URL=http://localhost:8080

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Admin credentials (for admin tests)
ADMIN_EMAIL=admin@aeroxe.com
ADMIN_PASSWORD=

# Member credentials (for member tests)
MEMBER_EMAIL=testmember@example.com
MEMBER_PASSWORD=TestPassword123!

# Optional: Run in CI mode (retries, no --only)
CI=false
