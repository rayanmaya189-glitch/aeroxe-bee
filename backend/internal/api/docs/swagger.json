{
  "openapi": "3.0.3",
  "info": {
    "title": "AeroXe Bee API",
    "description": "Distributed SMS gateway platform with intelligent routing, device fleet management, and delivery confidence scoring.",
    "version": "1.0.0",
    "contact": {
      "name": "Aeroxe Enterprises Pvt. Ltd.",
      "email": "support@aeroxbee.com",
      "url": "https://aeroxbee.com"
    },
    "license": {
      "name": "Proprietary",
      "url": "https://aeroxbee.com/license"
    }
  },
  "servers": [
    { "url": "http://localhost:8080", "description": "Development" },
    { "url": "https://api.aeroxbee.com", "description": "Production" }
  ],
  "tags": [
    { "name": "Health", "description": "Health check endpoints" },
    { "name": "Auth", "description": "Authentication and account management" },
    { "name": "Messages", "description": "SMS message sending and retrieval" },
    { "name": "OTP", "description": "One-time password generation and verification" },
    { "name": "Devices", "description": "Physical device registration and management" },
    { "name": "QR Pairing", "description": "QR code-based device pairing" },
    { "name": "Account", "description": "Account profile, API keys, and usage" },
    { "name": "Templates", "description": "SMS template management" },
    { "name": "Webhooks", "description": "Webhook endpoint configuration" },
    { "name": "Billing", "description": "Plans, billing, and invoicing" },
    { "name": "Admin", "description": "Admin-only dashboard and management endpoints" },
    { "name": "Member", "description": "Member portal endpoints" },
    { "name": "Fraud", "description": "Fraud detection and abuse flagging" },
    { "name": "App Releases", "description": "App version management, in-app updates, and maker-checker release flow" },
    { "name": "Firebase Config", "description": "Firebase Remote Config key-value management for feature flags and app settings" },
    { "name": "Public", "description": "Public endpoints (no auth required)" }
  ],
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "operationId": "healthCheck",
        "security": [],
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/APIResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "status": { "type": "string", "enum": ["healthy", "degraded"] },
                            "timestamp": { "type": "string", "format": "date-time" }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/health/mqtt": {
      "get": {
        "tags": ["Health"],
        "summary": "MQTT broker health check",
        "operationId": "mqttHealthCheck",
        "security": [],
        "responses": {
          "200": { "description": "MQTT broker status" },
          "503": { "description": "MQTT broker is not connected" }
        }
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new account",
        "operationId": "register",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string", "example": "John Doe" },
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "minLength": 8 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Account created" },
          "400": { "description": "Validation error" },
          "409": { "description": "Email already registered" }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login (staff or member)",
        "operationId": "login",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful (or 2FA required)" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/v1/send": {
      "post": {
        "tags": ["Messages"],
        "summary": "Send an SMS message",
        "operationId": "sendMessage",
        "security": [{ "APIKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["recipient", "message"],
                "properties": {
                  "recipient": { "type": "string", "example": "+1234567890" },
                  "message": { "type": "string" },
                  "sender": { "type": "string" },
                  "message_type": { "type": "string", "enum": ["otp", "transactional", "marketing"] }
                }
              }
            }
          }
        },
        "responses": {
          "202": { "description": "Message queued" },
          "400": { "description": "Validation error" },
          "401": { "description": "Invalid API key" },
          "429": { "description": "Rate limited" }
        }
      }
    },
    "/api/v1/devices/login": {
      "post": {
        "tags": ["Devices"],
        "summary": "Device login (email/password)",
        "operationId": "deviceLogin",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "device_id"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" },
                  "device_id": { "type": "string" },
                  "sim_slot": { "type": "integer", "default": 1 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful, returns JWT + MQTT credentials" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/v1/devices/qr-login": {
      "post": {
        "tags": ["QR Pairing"],
        "summary": "Device login via QR code",
        "operationId": "deviceQRLogin",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["pairing_token", "device_id"],
                "properties": {
                  "pairing_token": { "type": "string" },
                  "device_id": { "type": "string" },
                  "phone_number": { "type": "string" },
                  "carrier": { "type": "string" },
                  "sim_slot": { "type": "integer", "default": 1 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Device paired successfully" },
          "401": { "description": "Invalid pairing token" },
          "409": { "description": "Token already used" },
          "410": { "description": "Token expired" }
        }
      }
    },
    "/api/v1/member/devices/qr-code": {
      "post": {
        "tags": ["QR Pairing"],
        "summary": "Generate QR pairing token",
        "operationId": "generateQRCode",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "QR pairing token generated",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/APIResponse" },
                    { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/QRCodeResponse" } } }
                  ]
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/v1/member/plan": {
      "get": {
        "tags": ["Member"],
        "summary": "Get current plan and quota details",
        "operationId": "getMemberPlan",
        "security": [{ "BearerAuth": [] }],
        "description": "Returns the member's current subscription plan details, daily/monthly usage, and remaining quota. Protected by plan middleware — blocks suspended accounts and canceled subscriptions.",
        "responses": {
          "200": {
            "description": "Plan details with usage and quota info",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/APIResponse" },
                    { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/MemberPlanResponse" } } }
                  ]
                }
              }
            }
          },
          "403": { "description": "Account suspended/disabled or subscription canceled/past due" }
        }
      }
    },
    "/api/v1/public/plans": {
      "get": {
        "tags": ["Public"],
        "summary": "List public plans",
        "operationId": "listPublicPlans",
        "security": [],
        "responses": {
          "200": {
            "description": "List of public plans",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/APIResponse" },
                    { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/Plan" } } } }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/public/payment-methods": {
      "get": {
        "tags": ["Public"],
        "summary": "List accepted payment methods",
        "operationId": "listPaymentMethods",
        "security": [],
        "responses": {
          "200": {
            "description": "Enabled payment methods",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/APIResponse" },
                    { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object", "properties": { "method": { "type": "string" }, "label": { "type": "string" } } } } } }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/version-check": {
      "get": {
        "tags": ["App Releases"],
        "summary": "Check for app updates (Android client)",
        "operationId": "versionCheck",
        "security": [],
        "description": "Public endpoint (no auth). Android app calls this on startup to check if a newer version is available.",
        "parameters": [
          {
            "name": "version_code",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Current app version code (BuildConfig.VERSION_CODE)"
          }
        ],
        "responses": {
          "200": {
            "description": "Version check result",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/APIResponse" },
                    { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/VersionCheckResponse" } } }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/admin/releases": {
      "get": {
        "tags": ["App Releases"],
        "summary": "List all app releases",
        "operationId": "listReleases",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of releases ordered by version_code desc",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/APIResponse" },
                    { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/AppRelease" } } } }
                  ]
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["App Releases"],
        "summary": "Create a new app release draft",
        "operationId": "createRelease",
        "description": "Any authenticated user can create (maker role). The release starts in 'draft' status.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["version_code", "version_name"],
                "properties": {
                  "version_code": { "type": "integer", "example": 2 },
                  "version_name": { "type": "string", "example": "1.1.0" },
                  "release_type": { "type": "string", "enum": ["force", "normal"], "default": "normal" },
                  "title": { "type": "string" },
                  "release_notes": { "type": "string" },
                  "min_required_version": { "type": "integer", "default": 1 },
                  "apk_url": { "type": "string", "description": "External APK download URL" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Release created" },
          "400": { "description": "Validation error" },
          "409": { "description": "version_code already exists" }
        }
      }
    },
    "/api/v1/admin/releases/{id}": {
      "get": {
        "tags": ["App Releases"],
        "summary": "Get release details",
        "operationId": "getRelease",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Release details",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/APIResponse" },
                    { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/AppRelease" } } }
                  ]
                }
              }
            }
          },
          "404": { "description": "Release not found" }
        }
      },
      "delete": {
        "tags": ["App Releases"],
        "summary": "Delete a release (admin only)",
        "operationId": "deleteRelease",
        "description": "Only admin can delete. Only draft or rejected releases can be deleted.",
        "security": [{ "AdminAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Release deleted" },
          "400": { "description": "Cannot delete released or approved releases" }
        }
      }
    },
    "/api/v1/admin/releases/{id}/submit": {
      "post": {
        "tags": ["App Releases"],
        "summary": "Submit release for approval (maker)",
        "operationId": "submitRelease",
        "description": "Any authenticated user can submit a draft release for admin approval.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Submitted for approval" },
          "400": { "description": "Release is not in draft status" },
          "404": { "description": "Release not found" }
        }
      }
    },
    "/api/v1/admin/releases/{id}/approve": {
      "post": {
        "tags": ["App Releases"],
        "summary": "Approve release (admin only)",
        "operationId": "approveRelease",
        "description": "Admin reviews and approves a pending release.",
        "security": [{ "AdminAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Release approved" },
          "403": { "description": "Only admin can approve" },
          "404": { "description": "Release not found" }
        }
      }
    },
    "/api/v1/admin/releases/{id}/reject": {
      "post": {
        "tags": ["App Releases"],
        "summary": "Reject release (admin only)",
        "operationId": "rejectRelease",
        "description": "Admin rejects a pending release with a reason.",
        "security": [{ "AdminAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reason": { "type": "string", "description": "Rejection reason" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Release rejected" },
          "403": { "description": "Only admin can reject" },
          "404": { "description": "Release not found" }
        }
      }
    },
    "/api/v1/admin/releases/{id}/release": {
      "post": {
        "tags": ["App Releases"],
        "summary": "Publish release (admin only)",
        "operationId": "publishRelease",
        "description": "Admin publishes an approved release, making it the active version for all Android clients.",
        "security": [{ "AdminAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Release published" },
          "403": { "description": "Only admin can publish" },
          "404": { "description": "Release not found" }
        }
      }
    },
    "/api/v1/admin/releases/{id}/upload": {
      "post": {
        "tags": ["App Releases"],
        "summary": "Upload APK file for a release",
        "operationId": "uploadAPK",
        "description": "Upload an APK file (max 100MB) and associate it with a draft release.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["apk"],
                "properties": {
                  "apk": { "type": "string", "format": "binary", "description": "APK file" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "APK uploaded and associated with release",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/APIResponse" },
                    { "type": "object", "properties": { "data": { "type": "object", "properties": { "filename": { "type": "string" }, "file_path": { "type": "string" }, "size_bytes": { "type": "integer" }, "download_url": { "type": "string" } } } } }
                  ]
                }
              }
            }
          },
          "400": { "description": "File too large or not an APK" }
        }
      }
    },
    "/api/v1/admin/firebase-config": {
      "get": {
        "tags": ["Firebase Config"],
        "summary": "List all Firebase config entries (admin)",
        "operationId": "listFirebaseConfig",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "All config entries including sensitive ones",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/APIResponse" },
                    { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/FirebaseConfigEntry" } } } }
                  ]
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Firebase Config"],
        "summary": "Bulk update Firebase config entries (admin only)",
        "operationId": "bulkUpdateFirebaseConfig",
        "security": [{ "AdminAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "entries": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/FirebaseConfigEntry" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Config updated" },
          "403": { "description": "Only admin can bulk update" }
        }
      }
    },
    "/api/v1/admin/firebase-config/{key}": {
      "put": {
        "tags": ["Firebase Config"],
        "summary": "Upsert a single Firebase config entry (admin only)",
        "operationId": "upsertFirebaseConfig",
        "security": [{ "AdminAuth": [] }],
        "parameters": [
          { "name": "key", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "value": { "type": "string" },
                  "value_type": { "type": "string", "enum": ["string", "boolean", "integer"] },
                  "category": { "type": "string" },
                  "description": { "type": "string" },
                  "is_sensitive": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Config entry created or updated" },
          "403": { "description": "Only admin can update" }
        }
      },
      "delete": {
        "tags": ["Firebase Config"],
        "summary": "Delete a Firebase config entry (admin only)",
        "operationId": "deleteFirebaseConfig",
        "security": [{ "AdminAuth": [] }],
        "parameters": [
          { "name": "key", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Config entry deleted" },
          "403": { "description": "Only admin can delete" }
        }
      }
    },
    "/api/v1/firebase-config": {
      "get": {
        "tags": ["Firebase Config"],
        "summary": "Get public Firebase config (Android client)",
        "operationId": "getPublicFirebaseConfig",
        "security": [],
        "description": "Public endpoint (no auth). Returns non-sensitive config entries as a key-value map.",
        "responses": {
          "200": {
            "description": "Public config map",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/APIResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "description": "Key-value map of non-sensitive config entries",
                          "additionalProperties": true
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token from login endpoint."
      },
      "APIKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key passed as Bearer token."
      },
      "AdminAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Admin/staff JWT token with admin claim."
      }
    },
    "schemas": {
      "APIResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {},
          "error": { "type": "string" }
        }
      },
      "QRCodeResponse": {
        "type": "object",
        "description": "QR pairing token response",
        "properties": {
          "token": { "type": "string", "description": "Pairing token (64 hex chars)" },
          "expires_at": { "type": "string", "format": "date-time" },
          "qr_data": { "type": "string", "description": "JSON payload for QR code" }
        }
      },
      "AppRelease": {
        "type": "object",
        "description": "App release with version info and approval workflow status",
        "properties": {
          "id": { "type": "string" },
          "version_code": { "type": "integer" },
          "version_name": { "type": "string" },
          "release_type": { "type": "string", "enum": ["force", "normal"] },
          "title": { "type": "string" },
          "release_notes": { "type": "string" },
          "min_required_version": { "type": "integer" },
          "apk_url": { "type": "string" },
          "apk_filename": { "type": "string" },
          "apk_size_bytes": { "type": "integer" },
          "status": { "type": "string", "enum": ["draft", "pending_approval", "approved", "released", "rejected"] },
          "submitted_by_name": { "type": "string" },
          "approved_by_name": { "type": "string" },
          "rejection_reason": { "type": "string" },
          "released_at": { "type": "string", "format": "date-time" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
