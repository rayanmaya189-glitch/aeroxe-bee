{
  "openapi": "3.0.3",
  "info": {
    "title": "AeroXe Bee API",
    "description": "Distributed SMS gateway platform with intelligent routing, device fleet management, and delivery confidence scoring.",
    "version": "1.0.0",
    "contact": {
      "name": "Aeroxe Enterprises Pvt. Ltd.",
      "email": "support@aeroxbee.com",
      "url": "https://aeroxbee.com"
    },
    "license": {
      "name": "Proprietary",
      "url": "https://aeroxbee.com/license"
    }
  },
  "servers": [
    { "url": "http://localhost:8080", "description": "Development" },
    { "url": "https://api.aeroxbee.com", "description": "Production" }
  ],
  "tags": [
    { "name": "Health", "description": "Health check endpoints" },
    { "name": "Auth", "description": "Authentication and account management" },
    { "name": "Messages", "description": "SMS message sending and retrieval" },
    { "name": "OTP", "description": "One-time password generation and verification" },
    { "name": "Devices", "description": "Physical device registration and management" },
    { "name": "Account", "description": "Account profile, API keys, and usage" },
    { "name": "Templates", "description": "SMS template management" },
    { "name": "Webhooks", "description": "Webhook endpoint configuration" },
    { "name": "Billing", "description": "Plans, billing, and invoicing" },
    { "name": "Admin", "description": "Admin-only dashboard and management endpoints" },
    { "name": "Member", "description": "Member portal endpoints" },
    { "name": "Fraud", "description": "Fraud detection and abuse flagging" },
    { "name": "Public", "description": "Public endpoints (no auth required)" }
  ],
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "description": "Returns the health status of the API server, database, and Redis.",
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/APIResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "status": { "type": "string", "enum": ["healthy", "degraded"] },
                            "timestamp": { "type": "string", "format": "date-time" },
                            "checks": {
                              "type": "object",
                              "properties": {
                                "postgres": { "type": "string" },
                                "redis": { "type": "string" }
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/health/mqtt": {
      "get": {
        "tags": ["Health"],
        "summary": "MQTT broker health check",
        "description": "Returns the connection status of the MQTT broker (Mosquitto). Reports whether the backend can communicate with the message broker.",
        "operationId": "mqttHealthCheck",
        "responses": {
          "200": {
            "description": "MQTT broker is connected",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/APIResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "service": { "type": "string", "example": "mqtt" },
                            "status": { "type": "string", "enum": ["up", "down"] }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "503": {
            "description": "MQTT broker is not connected"
          }
        }
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new account",
        "operationId": "register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string", "example": "John Doe" },
                  "email": { "type": "string", "format": "email", "example": "john@example.com" },
                  "password": { "type": "string", "minLength": 8, "example": "SecureP@ss123" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Account created successfully" },
          "400": { "description": "Validation error" },
          "409": { "description": "Email already registered" }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login (staff or member)",
        "operationId": "login",
        "description": "Authenticates against both the users table (staff/admin) and accounts table (members). If 2FA is enabled, returns a temporary token for the second step.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful (or 2FA required)",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/APIResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "token": { "type": "string" },
                            "refreshToken": { "type": "string" },
                            "requires_2fa": { "type": "boolean" },
                            "two_fa_token": { "type": "string" },
                            "user": { "$ref": "#/components/schemas/UserProfile" }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/v1/auth/profile": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get current user profile",
        "operationId": "getProfile",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Profile returned" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "tags": ["Auth"],
        "summary": "Update profile name",
        "operationId": "updateProfile",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Profile updated" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/v1/auth/change-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Change password",
        "operationId": "changePassword",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["old_password", "new_password"],
                "properties": {
                  "old_password": { "type": "string" },
                  "new_password": { "type": "string", "minLength": 8 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password changed" },
          "401": { "description": "Incorrect password" }
        }
      }
    },
    "/api/v1/auth/login/2fa": {
      "post": {
        "tags": ["Auth"],
        "summary": "Complete 2FA login",
        "operationId": "login2FA",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["token", "code"],
                "properties": {
                  "token": { "type": "string", "description": "Temporary 2FA token from first login step" },
                  "code": { "type": "string", "description": "6-digit TOTP code" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "2FA verified, full tokens issued" },
          "401": { "description": "Invalid 2FA code" }
        }
      }
    },
    "/api/v1/send": {
      "post": {
        "tags": ["Messages"],
        "summary": "Send an SMS message",
        "operationId": "sendMessage",
        "description": "Queues an SMS message for delivery. Messages are routed through eligible devices based on the account's routing strategy.",
        "security": [{ "APIKeyAuth": [] }],
        "parameters": [
          {
            "name": "X-API-Version",
            "in": "header",
            "required": false,
            "schema": { "type": "integer", "default": 1 },
            "description": "API version for backward compatibility. Defaults to 1. Stored in request context for future version-specific behavior."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["recipient", "message"],
                "properties": {
                  "recipient": { "type": "string", "example": "+1234567890" },
                  "message": { "type": "string", "example": "Your OTP is 4829" },
                  "sender": { "type": "string" },
                  "message_type": { "type": "string", "enum": ["otp", "transactional", "marketing"], "default": "transactional" },
                  "routing_strategy": { "type": "string", "enum": ["fastest_delivery", "lowest_cost", "highest_reliability", "geo_affinity", "profit_optimized"] },
                  "idempotency_key": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "202": { "description": "Message accepted and queued" },
          "400": { "description": "Validation error" },
          "401": { "description": "Invalid API key" },
          "429": { "description": "Rate limited" }
        }
      }
    },
    "/api/v1/messages": {
      "get": {
        "tags": ["Messages"],
        "summary": "List messages",
        "operationId": "listMessages",
        "security": [{ "APIKeyAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "pageSize", "in": "query", "schema": { "type": "integer", "default": 50 } },
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "message_type", "in": "query", "schema": { "type": "string", "enum": ["otp", "transactional", "marketing"] } }
        ],
        "responses": {
          "200": { "description": "Paginated message list" },
          "401": { "description": "Invalid API key" }
        }
      }
    },
    "/api/v1/messages/{id}": {
      "get": {
        "tags": ["Messages"],
        "summary": "Get message by ID",
        "operationId": "getMessage",
        "security": [{ "APIKeyAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Message details" },
          "404": { "description": "Message not found" }
        }
      }
    },
    "/api/v1/otp/send": {
      "post": {
        "tags": ["OTP"],
        "summary": "Send an OTP",
        "operationId": "sendOTP",
        "security": [{ "APIKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["phone"],
                "properties": {
                  "phone": { "type": "string", "example": "+1234567890" },
                  "template": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "202": { "description": "OTP sent" },
          "429": { "description": "Too many OTP requests" }
        }
      }
    },
    "/api/v1/otp/verify": {
      "post": {
        "tags": ["OTP"],
        "summary": "Verify an OTP",
        "operationId": "verifyOTP",
        "security": [{ "APIKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["phone", "code"],
                "properties": {
                  "phone": { "type": "string" },
                  "code": { "type": "string", "example": "482916" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OTP verified" },
          "401": { "description": "Invalid or expired OTP" }
        }
      }
    },
    "/api/v1/devices": {
      "get": {
        "tags": ["Devices"],
        "summary": "List devices",
        "operationId": "listDevices",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "List of devices" }
        }
      }
    },
    "/api/v1/devices/{id}": {
      "get": {
        "tags": ["Devices"],
        "summary": "Get device details",
        "operationId": "getDevice",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Device details" },
          "404": { "description": "Device not found" }
        }
      }
    },
    "/api/v1/devices/register": {
      "post": {
        "tags": ["Devices"],
        "summary": "Register a new device",
        "operationId": "registerDevice",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["model", "os_version"],
                "properties": {
                  "model": { "type": "string" },
                  "os_version": { "type": "string" },
                  "app_version": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Device registered" }
        }
      }
    },
    "/api/v1/account/api-keys": {
      "get": {
        "tags": ["Account"],
        "summary": "List API keys",
        "operationId": "listAPIKeys",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "List of API keys" }
        }
      },
      "post": {
        "tags": ["Account"],
        "summary": "Create API key",
        "operationId": "createAPIKey",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "label": { "type": "string" },
                  "scopes": { "type": "array", "items": { "type": "string" } },
                  "expires_at": { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "API key created" }
        }
      }
    },
    "/api/v1/account/subscription": {
      "get": {
        "tags": ["Account"],
        "summary": "Get current subscription",
        "operationId": "getSubscription",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Subscription details" }
        }
      }
    },
    "/api/v1/plans": {
      "get": {
        "tags": ["Billing"],
        "summary": "List plans (admin)",
        "operationId": "listPlans",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "List of all plans" }
        }
      },
      "post": {
        "tags": ["Billing"],
        "summary": "Create a plan (admin only)",
        "operationId": "createPlan",
        "security": [{ "AdminAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id", "name"],
                "properties": {
                  "id": { "type": "string" },
                  "name": { "type": "string" },
                  "visibility": { "type": "string", "enum": ["public", "private", "custom"] },
                  "daily_quota": { "type": "integer" },
                  "monthly_quota": { "type": "integer" },
                  "monthly_price": { "type": "number" },
                  "price_per_sms": { "type": "number" },
                  "max_devices": { "type": "integer" },
                  "features": { "type": "array", "items": { "type": "string" } },
                  "is_popular": { "type": "boolean" },
                  "cta_text": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Plan created" },
          "403": { "description": "Admin only" }
        }
      }
    },
    "/api/v1/plans/{id}": {
      "get": {
        "tags": ["Billing"],
        "summary": "Get plan by ID",
        "operationId": "getPlan",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Plan details" },
          "404": { "description": "Plan not found" }
        }
      },
      "put": {
        "tags": ["Billing"],
        "summary": "Update a plan (admin only)",
        "operationId": "updatePlan",
        "security": [{ "AdminAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Plan" }
            }
          }
        },
        "responses": {
          "200": { "description": "Plan updated" },
          "403": { "description": "Admin only" }
        }
      },
      "delete": {
        "tags": ["Billing"],
        "summary": "Delete a plan (admin only)",
        "operationId": "deletePlan",
        "security": [{ "AdminAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Plan deleted" },
          "403": { "description": "Admin only" }
        }
      }
    },
    "/api/v1/templates": {
      "get": {
        "tags": ["Templates"],
        "summary": "List templates (admin)",
        "operationId": "listTemplates",
        "security": [{ "AdminAuth": [] }],
        "responses": {
          "200": { "description": "List of templates" }
        }
      },
      "post": {
        "tags": ["Templates"],
        "summary": "Create template (admin)",
        "operationId": "createTemplate",
        "security": [{ "AdminAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "body"],
                "properties": {
                  "name": { "type": "string" },
                  "body": { "type": "string" },
                  "variables": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Template created" }
        }
      }
    },
    "/api/v1/webhooks": {
      "get": {
        "tags": ["Webhooks"],
        "summary": "List webhooks (admin)",
        "operationId": "listWebhooks",
        "security": [{ "AdminAuth": [] }],
        "responses": {
          "200": { "description": "List of webhooks" }
        }
      },
      "post": {
        "tags": ["Webhooks"],
        "summary": "Create webhook (admin)",
        "operationId": "createWebhook",
        "security": [{ "AdminAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["url", "events"],
                "properties": {
                  "url": { "type": "string", "format": "uri" },
                  "events": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Webhook created" }
        }
      }
    },
    "/api/v1/admin/stats": {
      "get": {
        "tags": ["Admin"],
        "summary": "Dashboard statistics",
        "operationId": "getAdminStats",
        "security": [{ "AdminAuth": [] }],
        "responses": {
          "200": { "description": "Dashboard stats" }
        }
      }
    },
    "/api/v1/admin/accounts": {
      "get": {
        "tags": ["Admin"],
        "summary": "List all accounts",
        "operationId": "listAccounts",
        "security": [{ "AdminAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "pageSize", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "status", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Paginated account list" }
        }
      }
    },
    "/api/v1/admin/analytics": {
      "get": {
        "tags": ["Admin"],
        "summary": "Analytics data",
        "operationId": "getAnalytics",
        "security": [{ "AdminAuth": [] }],
        "responses": {
          "200": { "description": "Analytics breakdown" }
        }
      }
    },
    "/api/v1/admin/circuit-breakers": {
      "get": {
        "tags": ["Admin"],
        "summary": "List circuit breakers",
        "operationId": "getCircuitBreakers",
        "security": [{ "AdminAuth": [] }],
        "responses": {
          "200": { "description": "Circuit breaker states" }
        }
      }
    },
    "/api/v1/admin/fraud-flags": {
      "get": {
        "tags": ["Admin"],
        "summary": "List fraud flags",
        "operationId": "getFraudFlags",
        "security": [{ "AdminAuth": [] }],
        "responses": {
          "200": { "description": "Fraud flag list" }
        }
      }
    },
    "/api/v1/admin/users": {
      "get": {
        "tags": ["Admin"],
        "summary": "List admin panel users",
        "operationId": "listUsers",
        "security": [{ "AdminAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "pageSize", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "role", "in": "query", "schema": { "type": "string", "enum": ["admin", "staff", "viewer"] } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["active", "inactive", "suspended"] } }
        ],
        "responses": {
          "200": { "description": "Paginated user list" }
        }
      },
      "post": {
        "tags": ["Admin"],
        "summary": "Create admin user",
        "operationId": "createUser",
        "security": [{ "AdminAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "minLength": 8 },
                  "role": { "type": "string", "enum": ["admin", "staff", "viewer"], "default": "staff" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User created" }
        }
      }
    },
    "/api/v1/member/dashboard": {
      "get": {
        "tags": ["Member"],
        "summary": "Member dashboard",
        "operationId": "getMemberDashboard",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Dashboard data" }
        }
      }
    },
    "/api/v1/member/devices": {
      "get": {
        "tags": ["Member"],
        "summary": "List member devices",
