{
  "openapi": "3.0.3",
  "info": {
    "title": "AeroXe Bee API",
    "description": "Distributed SMS gateway platform with intelligent routing, device fleet management, and delivery confidence scoring.",
    "version": "1.0.0",
    "contact": {
      "name": "Aeroxe Enterprises Pvt. Ltd.",
      "email": "support@aeroxbee.com",
      "url": "https://aeroxbee.com"
    },
    "license": {
      "name": "Proprietary",
      "url": "https://aeroxbee.com/license"
    }
  },
  "servers": [
    { "url": "http://localhost:8080", "description": "Development" },
    { "url": "https://api.aeroxbee.com", "description": "Production" }
  ],
  "tags": [
    { "name": "Health", "description": "Health check endpoints" },
    { "name": "Auth", "description": "Authentication and account management" },
    { "name": "Messages", "description": "SMS message sending and retrieval" },
    { "name": "OTP", "description": "One-time password generation and verification" },
    { "name": "Devices", "description": "Physical device registration and management" },
    { "name": "QR Pairing", "description": "QR code-based device pairing" },
    { "name": "Account", "description": "Account profile, API keys, and usage" },
    { "name": "Templates", "description": "SMS template management" },
    { "name": "Webhooks", "description": "Webhook endpoint configuration" },
    { "name": "Billing", "description": "Plans, billing, and invoicing" },
    { "name": "Admin", "description": "Admin-only dashboard and management endpoints" },
    { "name": "Member", "description": "Member portal endpoints" },
    { "name": "Fraud", "description": "Fraud detection and abuse flagging" },
    { "name": "Public", "description": "Public endpoints (no auth required)" }
  ],
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "description": "Returns the health status of the API server, database, and Redis.",
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/APIResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "status": { "type": "string", "enum": ["healthy", "degraded"] },
                            "timestamp": { "type": "string", "format": "date-time" },
                            "checks": {
                              "type": "object",
                              "properties": {
                                "postgres": { "type": "string" },
                                "redis": { "type": "string" }
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/health/mqtt": {
      "get": {
        "tags": ["Health"],
        "summary": "MQTT broker health check",
        "description": "Returns the connection status of the MQTT broker (Mosquitto).",
        "operationId": "mqttHealthCheck",
        "responses": {
          "200": {
            "description": "MQTT broker is connected",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/APIResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "service": { "type": "string", "example": "mqtt" },
                            "status": { "type": "string", "enum": ["up", "down"] }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "503": { "description": "MQTT broker is not connected" }
        }
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new account",
        "operationId": "register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string", "example": "John Doe" },
                  "email": { "type": "string", "format": "email", "example": "john@example.com" },
                  "password": { "type": "string", "minLength": 8, "example": "SecureP@ss123" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Account created successfully" },
          "400": { "description": "Validation error" },
          "409": { "description": "Email already registered" }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login (staff or member)",
        "operationId": "login",
        "description": "Authenticates against both the users table (staff/admin) and accounts table (members).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful (or 2FA required)" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/v1/send": {
      "post": {
        "tags": ["Messages"],
        "summary": "Send an SMS message",
        "operationId": "sendMessage",
        "description": "Queues an SMS message for delivery.",
        "security": [{ "APIKeyAuth": [] }],
        "parameters": [
          {
            "name": "X-API-Version",
            "in": "header",
            "required": false,
            "schema": { "type": "integer", "default": 1 },
            "description": "API version for backward compatibility."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["recipient", "message"],
                "properties": {
                  "recipient": { "type": "string", "example": "+1234567890" },
                  "message": { "type": "string", "example": "Your OTP is 4829" },
                  "sender": { "type": "string" },
                  "message_type": { "type": "string", "enum": ["otp", "transactional", "marketing"], "default": "transactional" },
                  "routing_strategy": { "type": "string", "enum": ["fastest_delivery", "lowest_cost", "highest_reliability", "geo_affinity", "profit_optimized"] },
                  "idempotency_key": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "202": { "description": "Message accepted and queued" },
          "400": { "description": "Validation error" },
          "401": { "description": "Invalid API key" },
          "429": { "description": "Rate limited" }
        }
      }
    },
    "/api/v1/devices/login": {
      "post": {
        "tags": ["Devices"],
        "summary": "Device login (email/password)",
        "operationId": "deviceLogin",
        "description": "Authenticates a device via email/password. Creates or updates the device and returns MQTT credentials.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "device_id"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" },
                  "device_id": { "type": "string", "description": "Android device unique ID" },
                  "sim_slot": { "type": "integer", "default": 1 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful, returns JWT + MQTT credentials" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/v1/devices/qr-login": {
      "post": {
        "tags": ["QR Pairing"],
        "summary": "Device login via QR code",
        "operationId": "deviceQRLogin",
        "description": "Validates a QR pairing token generated by the member portal, creates the device, and returns MQTT credentials. The pairing token is single-use and expires after 5 minutes.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["pairing_token", "device_id"],
                "properties": {
                  "pairing_token": { "type": "string", "description": "Token scanned from QR code" },
                  "device_id": { "type": "string", "description": "Android device unique ID (ANDROID_ID)" },
                  "phone_number": { "type": "string", "description": "Device phone number for country detection" },
                  "carrier": { "type": "string", "description": "SIM carrier name" },
                  "sim_slot": { "type": "integer", "default": 1 },
                  "app_version": { "type": "string" },
                  "model": { "type": "string" },
                  "os_version": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Device paired successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/APIResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "device_id": { "type": "string" },
                            "is_new_device": { "type": "boolean" },
                            "token": { "type": "string", "description": "JWT for subsequent API calls" },
                            "mqtt": {
                              "type": "object",
                              "properties": {
                                "broker_url": { "type": "string" },
                                "username": { "type": "string" },
                                "password": { "type": "string" }
                              }
                            },
                            "device": {
                              "type": "object",
                              "properties": {
                                "id": { "type": "string" },
                                "name": { "type": "string" },
                                "sim_slot": { "type": "integer" },
                                "status": { "type": "string" },
                                "carrier": { "type": "string" }
                              }
                            },
                            "account": {
                              "type": "object",
                              "properties": {
                                "id": { "type": "string" },
                                "email": { "type": "string" },
                                "name": { "type": "string" }
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": { "description": "Invalid pairing token" },
          "409": { "description": "Pairing token already used" },
          "410": { "description": "Pairing token expired" }
        }
      }
    },
    "/api/v1/devices/register": {
      "post": {
        "tags": ["Devices"],
        "summary": "Register a new device (API key)",
        "operationId": "registerDevice",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["physical_device_id", "api_key"],
                "properties": {
                  "physical_device_id": { "type": "string" },
                  "phone_number": { "type": "string" },
                  "carrier": { "type": "string" },
                  "sim_slot": { "type": "integer" },
                  "app_version": { "type": "string" },
                  "model": { "type": "string" },
                  "os_version": { "type": "string" },
                  "api_key": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Device registered" }
        }
      }
    },
    "/api/v1/member/devices/qr-code": {
      "post": {
        "tags": ["QR Pairing"],
        "summary": "Generate QR pairing token",
        "operationId": "generateQRCode",
        "description": "Generates a short-lived (5 minute) pairing token for QR code device pairing. The frontend displays this token as a QR code. The Android app scans the QR code and calls POST /api/v1/devices/qr-login with the token. Only one active QR token per account at a time — generating a new one invalidates any previous unused token.",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "QR pairing token generated",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/APIResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/QRCodeResponse"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/v1/public/plans": {
      "get": {
        "tags": ["Public"],
        "summary": "List public plans",
        "operationId": "listPublicPlans",
        "responses": {
          "200": { "description": "List of public plans" }
        }
      }
    },
    "/api/v1/public/payment-methods": {
      "get": {
        "tags": ["Public"],
        "summary": "List accepted payment methods",
        "operationId": "listPaymentMethods",
        "responses": {
          "200": { "description": "Enabled payment methods" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token from login endpoint."
      },
      "APIKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key passed as Bearer token."
      },
      "AdminAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Admin/staff JWT token with admin claim."
      }
    },
    "schemas": {
      "APIResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {},
          "error": { "type": "string" }
        }
      },
      "QRCodeResponse": {
        "type": "object",
        "description": "QR pairing token response",
        "properties": {
          "token": {
            "type": "string",
            "description": "Pairing token (64 hex chars)"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time",
            "description": "Token expiration timestamp (5 minutes from generation)"
          },
          "qr_data": {
            "type": "string",
            "description": "JSON payload to encode in the QR code. Contains token, type, and server URL."
          }
        }
      },
      "UserProfile": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "role": { "type": "string", "enum": ["admin", "staff", "viewer", "member"] },
          "status": { "type": "string" },
          "avatar": { "type": "string" },
          "is_admin": { "type": "boolean" }
        }
      },
      "Plan": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "visibility": { "type": "string", "enum": ["public", "private", "custom"] },
          "daily_quota": { "type": "integer" },
          "monthly_quota": { "type": "integer" },
          "monthly_price": { "type": "number" },
          "price_per_sms": { "type": "number" },
          "max_devices": { "type": "integer" },
          "dedicated_pool": { "type": "boolean" },
          "default_routing_strategy": { "type": "string" },
          "is_popular": { "type": "boolean" },
          "cta_text": { "type": "string" },
          "features": { "type": "array", "items": { "type": "string" } }
        }
      },
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": {} },
          "total": { "type": "integer" },
          "page": { "type": "integer" },
          "page_size": { "type": "integer" },
          "total_pages": { "type": "integer" }
        }
      }
    }
  }
}
