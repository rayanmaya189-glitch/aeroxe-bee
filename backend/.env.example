# ============================================================================
# AeroXe Bee Backend - Environment Variables
# Aeroxe Enterprises Pvt. Ltd., Jalgaon, Maharashtra, India
# ============================================================================
# Copy this file to .env and fill in values for your environment.
# Variables without defaults require explicit configuration.

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_SHUTDOWN_TIMEOUT=10s

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=textbee
DB_PASSWORD=textbee
DB_NAME=textbee
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- MQTT (Mosquitto) ---
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=backend
MQTT_PASSWORD=dev-backend-mqtt-password
MQTT_CA_CERT=
MQTT_CLIENT_ID=textbee-backend
MQTT_QOS=1
MQTT_USE_TLS=false
MQTT_TLS_INSECURE=false
MQTT_KEEP_ALIVE=30s
MQTT_PING_TIMEOUT=10s

# --- JWT ---
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
JWT_ISSUER=textbee

# --- Encryption (AES-256-GCM) ---
# Must be a secure random string in production. Leave empty to disable encryption.
ENCRYPTION_MASTER_KEY=

# --- Queue (Redis Streams) ---
QUEUE_OTP_STREAM=otp_queue
QUEUE_TRANSACTIONAL_STREAM=transactional_queue
QUEUE_MARKETING_STREAM=marketing_queue
QUEUE_DEAD_LETTER_STREAM=dead_letter_queue
QUEUE_OTP_MAX_AGE=90s
QUEUE_TRANSACTIONAL_MAX_AGE=15m
QUEUE_MARKETING_MAX_AGE=15m
QUEUE_ANTI_STARVATION_RATIO=10
QUEUE_MAX_DEPTH=10000
QUEUE_CONSUMER_GROUP=textbee-workers
QUEUE_CONSUMER_NAME=worker-1
QUEUE_BLOCK_TIME=2s
QUEUE_CLAIM_INTERVAL=30s
QUEUE_IDLE_RETRY_THRESHOLD=60s
QUEUE_MAX_DELIVERY_ATTEMPTS=3
QUEUE_WORKER_COUNT=3

# --- Rate Limiting ---
RATE_LIMIT_DEVICE_PER_MIN=10
RATE_LIMIT_DEVICE_PER_HOUR=100
RATE_LIMIT_SEND_PACING_MIN=2s
RATE_LIMIT_SEND_PACING_MAX=5s
RATE_LIMIT_API_KEY_PER_MIN=60

# --- SIM Health ---
SIM_HEALTH_DEGRADED_THRESHOLD=0.6
SIM_HEALTH_BLOCKED_THRESHOLD=0.3
SIM_HEALTH_WINDOW=5m
SIM_HEALTH_TREND_WINDOW=3h
SIM_HEALTH_TREND_SLOPE=-0.05
SIM_HEALTH_CHECK_INTERVAL=1m

# --- Delivery Confidence ---
DELIVERY_REPORT_WEIGHT=0.5
DELIVERY_HISTORICAL_WEIGHT=0.3
DELIVERY_CARRIER_WEIGHT=0.2

# --- Circuit Breaker ---
CB_DEVICE_FAILURE_THRESHOLD=0.5
CB_DEVICE_WINDOW=5m
CB_DEVICE_COOLDOWN=2m
CB_DEVICE_HALF_OPEN_SUCCESSES=3
CB_ACCOUNT_FAILURE_MULTIPLIER=2.0
CB_ACCOUNT_COOLDOWN=5m
CB_CARRIER_FAILURE_THRESHOLD=0.3
CB_CARRIER_WINDOW=5m
CB_CARRIER_COOLDOWN=10m
CB_CARRIER_TRAFFIC_REDUCTION=0.5

# --- Webhook ---
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_RETRY_WINDOW=24h
WEBHOOK_BASE_BACKOFF=1m
WEBHOOK_MAX_BACKOFF=30m
WEBHOOK_DELIVERY_TIMEOUT=10s

# --- OTP ---
OTP_CODE_LENGTH=6
OTP_TTL=5m
OTP_MAX_ATTEMPTS=5
OTP_LOCKOUT_TTL=15m

# --- Telemetry ---
TELEMETRY_SERVICE_NAME=textbee-backend
TELEMETRY_PROMETHEUS_ENABLED=true
TELEMETRY_PROMETHEUS_PORT=9090
TELEMETRY_TRACING_ENABLED=false
TELEMETRY_TRACING_ENDPOINT=
TELEMETRY_TRACING_RATIO=0.1

# --- App ---
APP_ENV=development
LOG_LEVEL=info
LOG_FORMAT=json
IDEMPOTENCY_TTL=5m
MESSAGE_RETENTION=2160h
OTP_METADATA_RETENTION=8760h
PING_TIMEOUT=3s
HEARTBEAT_WINDOW=45s
MAX_RETRY_DEVICES=3

# --- CORS ---
# Comma-separated list of allowed origins. Defaults to localhost:5173,localhost:3000.
CORS_ALLOWED_ORIGINS=

# --- FCM (Firebase Cloud Messaging) ---
# Set FCM_ENABLED=true and provide your Firebase project ID to enable push notifications.
# FCM_SERVICE_ACCOUNT_PATH should point to your Firebase service account JSON key file.
FCM_ENABLED=false
FCM_PROJECT_ID=aeroxe-bee
FCM_SERVICE_ACCOUNT_PATH=

# --- Admin Seed ---
# Set these to create a stable admin account on first startup.
ADMIN_EMAIL=admin@aeroxe.com
ADMIN_PASSWORD=
