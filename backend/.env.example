# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=textbee
DB_PASSWORD=textbee
DB_NAME=textbee
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MQTT
MQTT_BROKER=192.168.18.13
MQTT_PORT=1883

# JWT
JWT_SECRET=change-me-in-production

# Encryption (AES-256-GCM)
ENCRYPTION_MASTER_KEY=change-encryption-key-in-production

# Queue
QUEUE_OTP_STREAM=otp_queue
QUEUE_TRANSACTIONAL_STREAM=transactional_queue
QUEUE_MARKETING_STREAM=marketing_queue

# Rate Limiting
RATE_LIMIT_DEVICE_PER_MIN=10
RATE_LIMIT_DEVICE_PER_HOUR=100

# SIM Health
SIM_HEALTH_DEGRADED_THRESHOLD=0.6
SIM_HEALTH_BLOCKED_THRESHOLD=0.3

# Delivery Confidence
DELIVERY_REPORT_WEIGHT=0.5
DELIVERY_HISTORICAL_WEIGHT=0.3
DELIVERY_CARRIER_WEIGHT=0.2

# OTP
OTP_CODE_LENGTH=6
OTP_TTL=5m
OTP_MAX_ATTEMPTS=5

# Observability
TELEMETRY_PROMETHEUS_ENABLED=true
TELEMETRY_PROMETHEUS_PORT=9090

# App
APP_ENV=development
LOG_LEVEL=info
LOG_FORMAT=json
